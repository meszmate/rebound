---
// Browse-view style tool cards, like the real panel: a dark card with a live
// demo strip on top. Each demo is a small CSS animation loop.
---

<section id="tools" class="scroll-mt-20 py-24 sm:py-32">
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div class="max-w-xl">
        <p class="text-sm font-medium text-live" data-reveal>The toolkit</p>
        <h2
          class="mt-3 text-balance text-3xl font-semibold tracking-[-0.03em] text-ink sm:text-[2.5rem] sm:leading-[1.1]"
          data-reveal
          style="--reveal-delay: 0.06s"
        >
          What&rsquo;s in the panel.
        </h2>
      </div>
      <p class="max-w-sm text-pretty text-[0.9375rem] leading-relaxed text-mute" data-reveal style="--reveal-delay: 0.12s">
        A few of the tools. Every one is batch-aware and a single undo.
      </p>
    </div>

    <div class="mt-10 grid grid-cols-2 gap-2.5 sm:grid-cols-3 lg:grid-cols-4" data-reveal style="--reveal-delay: 0.15s">
      <!-- Ease -->
      <div class="tc">
        <div class="tc-demo">
          <svg viewBox="0 0 120 56" class="h-full w-full">
            <line x1="14" y1="46" x2="106" y2="12" stroke="#3b3c40" stroke-width="1" stroke-dasharray="3 3"></line>
            <path d="M14 46 C 40 12, 66 12, 106 12" fill="none" stroke="#5496fa" stroke-width="2" stroke-linecap="round"></path>
            <circle r="3.5" fill="#5496fa" class="td-ease"></circle>
          </svg>
        </div>
        <div class="tc-label"><span>Ease</span><span class="tc-group">Easing</span></div>
      </div>

      <!-- Spring -->
      <div class="tc">
        <div class="tc-demo">
          <div class="absolute top-1/2 right-[18%] h-4 w-px -translate-y-1/2 bg-[#3b3c40]"></div>
          <div class="td-spring absolute top-1/2 left-[10%] h-3.5 w-3.5 -translate-y-1/2 rounded-full bg-[#5496fa]"></div>
        </div>
        <div class="tc-label"><span>Spring</span><span class="tc-group">Physics</span></div>
      </div>

      <!-- Bounce -->
      <div class="tc">
        <div class="tc-demo">
          <div class="absolute right-[14%] bottom-[22%] left-[14%] h-px bg-[#3b3c40]"></div>
          <div class="td-bounce absolute bottom-[22%] left-1/2 h-3.5 w-3.5 -translate-x-1/2 rounded-full bg-[#5496fa]"></div>
        </div>
        <div class="tc-label"><span>Bounce</span><span class="tc-group">Physics</span></div>
      </div>

      <!-- Follow -->
      <div class="tc">
        <div class="tc-demo">
          <div class="td-follow absolute top-1/2 left-[12%] h-3.5 w-3.5 -translate-y-1/2 rounded-full bg-[#5496fa]"></div>
          <div class="td-follow td-follow-2 absolute top-1/2 left-[12%] h-2.5 w-2.5 -translate-y-1/2 rounded-full bg-[#5496fa]/50"></div>
          <div class="td-follow td-follow-3 absolute top-1/2 left-[12%] h-2 w-2 -translate-y-1/2 rounded-full bg-[#5496fa]/25"></div>
        </div>
        <div class="tc-label"><span>Follow</span><span class="tc-group">Physics</span></div>
      </div>

      <!-- Stagger -->
      <div class="tc">
        <div class="tc-demo flex items-end justify-center gap-1.5 pb-3">
          {[0, 1, 2, 3, 4].map((i) => (
            <div class="td-stag w-3 rounded-t-sm bg-[#5496fa]" style={`animation-delay: ${i * 0.14}s;`}></div>
          ))}
        </div>
        <div class="tc-label"><span>Stagger</span><span class="tc-group">Timing</span></div>
      </div>

      <!-- Anchor -->
      <div class="tc">
        <div class="tc-demo">
          <svg viewBox="0 0 120 56" class="h-full w-full">
            <rect x="42" y="12" width="36" height="32" rx="2" fill="none" stroke="#58595c" stroke-width="1.2"></rect>
            {[42, 60, 78].map((x) => [12, 28, 44].map((y) => <circle cx={x} cy={y} r="1.6" fill="#6e727a" />))}
            <circle r="4" fill="none" stroke="#5496fa" stroke-width="1.8" class="td-anchor"></circle>
          </svg>
        </div>
        <div class="tc-label"><span>Anchor</span><span class="tc-group">Transform</span></div>
      </div>

      <!-- Align -->
      <div class="tc">
        <div class="tc-demo flex flex-col items-start justify-center gap-1.5 px-6">
          <div class="td-align h-2.5 w-12 rounded-sm bg-[#5496fa]/80" style="--from: 26px;"></div>
          <div class="td-align h-2.5 w-8 rounded-sm bg-[#5496fa]/55" style="--from: 8px;"></div>
          <div class="td-align h-2.5 w-14 rounded-sm bg-[#5496fa]/30" style="--from: 16px;"></div>
        </div>
        <div class="tc-label"><span>Align</span><span class="tc-group">Layout</span></div>
      </div>

      <!-- Trim Paths -->
      <div class="tc">
        <div class="tc-demo">
          <svg viewBox="0 0 120 56" class="h-full w-full">
            <path d="M36 28 C 36 15, 84 15, 84 28 C 84 41, 36 41, 36 28 Z" fill="none" stroke="#3b3c40" stroke-width="2"></path>
            <path d="M36 28 C 36 15, 84 15, 84 28 C 84 41, 36 41, 36 28 Z" fill="none" stroke="#5496fa" stroke-width="2" stroke-linecap="round" class="td-trim" pathLength="100"></path>
          </svg>
        </div>
        <div class="tc-label"><span>Trim Paths</span><span class="tc-group">Shapes</span></div>
      </div>

      <!-- Radial -->
      <div class="tc">
        <div class="tc-demo">
          <svg viewBox="0 0 120 56" class="h-full w-full">
            <circle cx="60" cy="28" r="2" fill="#6e727a"></circle>
            <g class="td-radial">
              {[0, 60, 120, 180, 240, 300].map((a) => (
                <circle cx={60 + 17 * Math.cos((a * Math.PI) / 180)} cy={28 + 17 * Math.sin((a * Math.PI) / 180)} r="3" fill="#5496fa" opacity={0.45 + 0.55 * (a / 300)} />
              ))}
            </g>
          </svg>
        </div>
        <div class="tc-label"><span>Radial</span><span class="tc-group">Generators</span></div>
      </div>

      <!-- Echo -->
      <div class="tc">
        <div class="tc-demo">
          <div class="td-echo absolute top-1/2 left-[10%] h-3.5 w-3.5 -translate-y-1/2 rounded-[3px] bg-[#5496fa]"></div>
          <div class="td-echo absolute top-1/2 left-[10%] h-3.5 w-3.5 -translate-y-1/2 rounded-[3px] bg-[#5496fa]/40" style="animation-delay: 0.12s"></div>
          <div class="td-echo absolute top-1/2 left-[10%] h-3.5 w-3.5 -translate-y-1/2 rounded-[3px] bg-[#5496fa]/15" style="animation-delay: 0.24s"></div>
        </div>
        <div class="tc-label"><span>Echo</span><span class="tc-group">Generators</span></div>
      </div>

      <!-- Text Break -->
      <div class="tc">
        <div class="tc-demo flex items-center justify-center gap-px font-mono text-[13px] font-semibold text-[#e3e5ea]">
          {'MOTION'.split('').map((ch, i) => (
            <span class="td-txt inline-block" style={`animation-delay: ${i * 0.09}s`}>{ch}</span>
          ))}
        </div>
        <div class="tc-label"><span>Text Break</span><span class="tc-group">Shapes</span></div>
      </div>

      <!-- Drift -->
      <div class="tc">
        <div class="tc-demo">
          <div class="td-drift absolute top-1/2 left-1/2 h-3.5 w-3.5 rounded-full bg-[#5496fa]"></div>
        </div>
        <div class="tc-label"><span>Drift</span><span class="tc-group">Physics</span></div>
      </div>
    </div>

    <p class="mt-6 text-sm text-faint" data-reveal>
      Part of the full toolkit: easing, physics, timing, transform, layout, generators, shapes,
      color, import, organize.
    </p>
  </div>
</section>

<style>
  .tc {
    overflow: hidden;
    border-radius: 8px;
    border: 1px solid #3b3c40;
    background: #2f3034;
    box-shadow: 0 1px 2px rgb(0 0 0 / 0.22);
    transition: transform 0.3s var(--ease-out-quart), box-shadow 0.3s var(--ease-out-quart);
  }
  .tc:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 24px -10px rgb(16 17 20 / 0.45);
  }
  .tc-demo {
    position: relative;
    height: 5rem;
    background: #17181b;
    overflow: hidden;
  }
  .tc-label {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: #e3e5ea;
  }
  .tc-group {
    font-size: 0.6875rem;
    font-weight: 400;
    color: #6e727a;
  }

  /* Ease: dot rides the curve */
  .td-ease {
    offset-path: path('M14 46 C 40 12, 66 12, 106 12');
    animation: td-ride 2.6s infinite;
  }
  @keyframes td-ride {
    0% { offset-distance: 0%; animation-timing-function: cubic-bezier(0.165, 0.84, 0.44, 1); }
    58%, 100% { offset-distance: 100%; }
  }

  /* Spring: overshoot to the target tick */
  @keyframes td-spring {
    0%, 8% { transform: translate(0, -50%); }
    38% { transform: translate(74px, -50%); }
    52% { transform: translate(60px, -50%); }
    66% { transform: translate(68px, -50%); }
    78% { transform: translate(64px, -50%); }
    88%, 100% { transform: translate(65px, -50%); }
  }
  .td-spring { animation: td-spring 2.8s cubic-bezier(0.3, 0, 0.3, 1) infinite; }

  /* Bounce: decaying rebounds on a floor */
  @keyframes td-bounce {
    0% { transform: translate(-50%, -30px); animation-timing-function: cubic-bezier(0.5, 0, 1, 1); }
    28% { transform: translate(-50%, 0); animation-timing-function: cubic-bezier(0, 0, 0.5, 1); }
    46% { transform: translate(-50%, -16px); animation-timing-function: cubic-bezier(0.5, 0, 1, 1); }
    62% { transform: translate(-50%, 0); animation-timing-function: cubic-bezier(0, 0, 0.5, 1); }
    73% { transform: translate(-50%, -7px); animation-timing-function: cubic-bezier(0.5, 0, 1, 1); }
    82% { transform: translate(-50%, 0); animation-timing-function: cubic-bezier(0, 0, 0.5, 1); }
    88% { transform: translate(-50%, -2px); animation-timing-function: cubic-bezier(0.5, 0, 1, 1); }
    92%, 100% { transform: translate(-50%, 0); }
  }
  .td-bounce { animation: td-bounce 2.6s infinite; }

  /* Follow: laggy chain */
  @keyframes td-follow {
    0%, 10% { left: 12%; }
    45%, 60% { left: 76%; }
    95%, 100% { left: 12%; }
  }
  .td-follow { animation: td-follow 3.2s cubic-bezier(0.45, 0, 0.25, 1) infinite; }
  .td-follow-2 { animation-delay: 0.14s; }
  .td-follow-3 { animation-delay: 0.26s; }

  /* Stagger: bars pop in sequence */
  @keyframes td-stag {
    0%, 8% { transform: scaleY(0.12); opacity: 0.35; }
    28%, 72% { transform: scaleY(1); opacity: 1; }
    88%, 100% { transform: scaleY(0.12); opacity: 0.35; }
  }
  .td-stag {
    height: 32px;
    transform-origin: bottom;
    animation: td-stag 2.8s cubic-bezier(0.3, 1.3, 0.4, 1) infinite;
  }

  /* Anchor: highlight hops between grid points */
  @keyframes td-anchor {
    0%, 18% { transform: translate(42px, 12px); }
    26%, 44% { transform: translate(78px, 12px); }
    52%, 70% { transform: translate(78px, 44px); }
    78%, 100% { transform: translate(60px, 28px); }
  }
  .td-anchor { animation: td-anchor 3.4s cubic-bezier(0.5, 0, 0.2, 1) infinite; }

  /* Align: bars snap to the left edge and back */
  @keyframes td-align {
    0%, 12% { transform: translateX(var(--from)); }
    36%, 68% { transform: translateX(0); }
    90%, 100% { transform: translateX(var(--from)); }
  }
  .td-align { animation: td-align 3s cubic-bezier(0.3, 1.2, 0.35, 1) infinite; }

  /* Trim Paths: draw on, hold, draw off */
  @keyframes td-trim {
    0% { stroke-dasharray: 0 100; }
    45%, 60% { stroke-dasharray: 100 100; }
    100% { stroke-dasharray: 0 100; stroke-dashoffset: -100; }
  }
  .td-trim { animation: td-trim 3s ease-in-out infinite; }

  /* Radial: ring spins */
  @keyframes td-radial {
    to { transform: rotate(360deg); }
  }
  .td-radial {
    transform-origin: 60px 28px;
    animation: td-radial 7s linear infinite;
  }

  /* Echo: square with trailing ghosts */
  @keyframes td-echo {
    0%, 12% { left: 10%; }
    55%, 62% { left: 78%; }
    100% { left: 10%; }
  }
  .td-echo { animation: td-echo 2.9s cubic-bezier(0.5, 0, 0.3, 1) infinite; }

  /* Text Break: letters hop in a wave */
  @keyframes td-txt {
    0%, 55%, 100% { transform: translateY(0); }
    70% { transform: translateY(-7px); }
    85% { transform: translateY(1px); }
  }
  .td-txt { animation: td-txt 2.4s cubic-bezier(0.3, 1.3, 0.4, 1) infinite; }

  /* Drift: organic wander */
  @keyframes td-drift {
    0% { transform: translate(-18px, -6px); }
    25% { transform: translate(6px, -14px); }
    50% { transform: translate(16px, 2px); }
    75% { transform: translate(-4px, 8px); }
    100% { transform: translate(-18px, -6px); }
  }
  .td-drift { animation: td-drift 5.5s ease-in-out infinite; }
</style>
