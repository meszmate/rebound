---
import Mark from './Mark.astro';

const REPO = 'https://github.com/meszmate/rebound';
const RELEASES = 'https://github.com/meszmate/rebound/releases';

const steps = [
  { n: '1', text: 'Download the latest .zxp from GitHub Releases' },
  { n: '2', text: 'Install it with any ZXP installer, like the free ZXPInstaller' },
  { n: '3', text: 'Restart After Effects' },
  { n: '4', text: 'Window ▸ Extensions ▸ Rebound' },
];
---

<section id="download" class="scroll-mt-20 pb-24 sm:pb-32">
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <div
      class="relative overflow-hidden rounded-3xl bg-[#17181b] px-6 py-16 text-center sm:px-12 sm:py-20"
      data-reveal
    >
      <!-- faint mark watermark, echoing the brand's social banner -->
      <Mark
        class="pointer-events-none absolute -right-10 -bottom-12 h-64 w-72 text-white opacity-[0.05]"
      />
      <div class="pointer-events-none absolute inset-0 [background-image:radial-gradient(rgb(255_255_255/0.04)_1px,transparent_1px)] [background-size:22px_22px]" aria-hidden="true"></div>

      <div class="relative mx-auto max-w-xl">
        <Mark class="mx-auto h-12 w-14 text-white" />
        <h2 class="mt-6 text-balance text-3xl font-semibold tracking-[-0.03em] text-white sm:text-4xl">
          Get Rebound for After Effects.
        </h2>
        <p class="mt-4 text-pretty text-[#9aa0a8]">
          After Effects 2019 or newer, on macOS and Windows. Free and open source under the MIT
          license. No account, no trial clock.
        </p>
        <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a
            href={RELEASES}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 rounded-full bg-white px-6 py-3 text-[0.9375rem] font-medium text-ink transition-all duration-300 [transition-timing-function:var(--ease-out-quart)] hover:-translate-y-px hover:shadow-[0_10px_30px_-10px_rgb(255_255_255/0.4)] active:scale-[0.97]"
          >
            Download the latest release
            <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path
                d="M5.5 3.5h7v7M12.5 3.5 3.5 12.5"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </a>
          <a
            href={REPO}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 rounded-full border border-white/15 px-6 py-3 text-[0.9375rem] font-medium text-white/90 transition-all duration-300 [transition-timing-function:var(--ease-out-quart)] hover:-translate-y-px hover:border-white/30 active:scale-[0.97]"
          >
            View source on GitHub
          </a>
        </div>

        <div class="mt-12 grid gap-4 text-left sm:grid-cols-4 sm:gap-2">
          {
            steps.map((s) => (
              <div class="flex items-start gap-3 sm:flex-col sm:gap-2.5">
                <span class="grid h-6 w-6 shrink-0 place-items-center rounded-full border border-white/15 text-xs font-medium text-white/70">
                  {s.n}
                </span>
                <p class="text-[0.8125rem] leading-relaxed text-[#9aa0a8]">{s.text}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
