---
// The Rebound bounce monogram — full mark, mono, inherits currentColor.
// Geometry mirrors the Branding Figma file (node 5:7) / client/js/core/brand.js.
interface Props {
  class?: string;
  animate?: boolean;
}
const { class: className = '', animate = false } = Astro.props;
---

<svg
  class:list={[className, { 'rb-mark-animate': animate }]}
  viewBox="0 0 170 155"
  fill="none"
  aria-hidden="true"
  focusable="false"
>
  <path
    class="rb-mark-path"
    d="M27.05 44.82C31.68 92.21 39.67 115.91 51 115.91C66.45 58.73 83.45 58.73 98.91 115.91C108.18 85 115.91 85 123.64 115.91C129.82 103.55 134.45 103.55 139.09 115.91"
    stroke="currentColor"
    stroke-width="10.05"
    stroke-linecap="round"
    stroke-linejoin="round"></path>
  <circle class="rb-mark-ball" cx="27.05" cy="34" r="11.59" fill="currentColor"></circle>
</svg>
