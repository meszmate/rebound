---
const principles = [
  { icon: 'M8 3v5m0 0L5.5 5.5M8 8l2.5-2.5M3 11.5h10', title: 'One undo per action' },
  { icon: 'M3 8a5 5 0 1 1 10 0A5 5 0 0 1 3 8Zm5-2.5V8l2 1.5', title: 'Preview before you apply' },
  { icon: 'M4 5h8M4 8h8M4 11h5', title: '⌘K command palette' },
  { icon: 'M8 2.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11Zm0 0v11', title: 'Follows AE’s theme' },
  { icon: 'M3 8.5 6.5 12 13 4.5', title: 'Bake to keys in one click' },
  { icon: 'M8 3 3 13h10L8 3Zm0 4v3m0 2v.5', title: 'No telemetry, no account' },
];
---

<section class="border-y border-line-soft bg-mist/50">
  <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-center gap-x-10 gap-y-4 px-5 py-8 sm:px-8">
    {
      principles.map((p) => (
        <span class="flex items-center gap-2.5 text-sm font-medium text-ink-soft" data-reveal>
          <svg viewBox="0 0 16 16" class="h-4 w-4 text-ink" fill="none" aria-hidden="true">
            <path d={p.icon} stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          {p.title}
        </span>
      ))
    }
  </div>
</section>
