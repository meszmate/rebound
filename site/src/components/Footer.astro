---
import Mark from './Mark.astro';

const year = new Date().getFullYear();
---

<footer class="border-t border-line">
  <div class="mx-auto max-w-6xl px-5 py-14 sm:px-8">
    <div class="flex flex-col justify-between gap-10 sm:flex-row sm:items-start">
      <div class="max-w-xs">
        <div class="flex items-center gap-2.5 text-ink">
          <Mark class="h-7 w-8" />
          <span class="text-[1.0625rem] font-semibold tracking-[-0.02em]">Rebound</span>
        </div>
        <p class="mt-3 text-sm leading-relaxed text-mute">
          Easing, springs &amp; motion-design tools for After Effects. Free for non-commercial
          use.
        </p>
      </div>

      <nav class="grid grid-cols-2 gap-x-16 gap-y-10 text-sm sm:grid-cols-3">
        <div class="flex flex-col gap-2.5">
          <span class="mb-1 font-medium text-ink">Product</span>
          <a href="#playground" class="text-mute transition-colors hover:text-ink">Playground</a>
          <a href="#boards" class="text-mute transition-colors hover:text-ink">Home board</a>
          <a href="#import" class="text-mute transition-colors hover:text-ink">Import</a>
          <a href="#tools" class="text-mute transition-colors hover:text-ink">Tools</a>
        </div>
        <div class="flex flex-col gap-2.5">
          <span class="mb-1 font-medium text-ink">Get started</span>
          <a href="#download" class="text-mute transition-colors hover:text-ink">Download</a>
          <a href="#pricing" class="text-mute transition-colors hover:text-ink">Pricing</a>
          <a href="#faq" class="text-mute transition-colors hover:text-ink">FAQ</a>
        </div>
        <div class="flex flex-col gap-2.5">
          <span class="mb-1 font-medium text-ink">Elsewhere</span>
          <a
            href="https://aescripts.com/rebound/"
            class="text-mute transition-colors hover:text-ink">aescripts + aeplugins</a
          >
        </div>
      </nav>
    </div>

    <div class="mt-12 border-t border-line-soft pt-6">
      <p class="text-xs leading-relaxed text-faint">
        © {year} Rebound. All rights reserved. Rebound is an independent product and is not
        affiliated with or endorsed by Adobe Inc. or Figma, Inc. After Effects and Adobe are
        trademarks of Adobe Inc. Figma is a trademark of Figma, Inc.
      </p>
    </div>
  </div>
</footer>
